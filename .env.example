# UE5 MCP Server Configuration
# Copy this file to .env and modify as needed

# Base URL for Unreal MCP server (the UnrealClaude plugin's HTTP endpoint)
# Default: http://localhost:3000
UNREAL_MCP_URL=http://localhost:3000

# HTTP request timeout in milliseconds
# Default: 30000 (30 seconds)
MCP_REQUEST_TIMEOUT_MS=30000

# Enable automatic context injection on tool responses
# Default: false
# INJECT_CONTEXT=true

# Async task polling (for long-running Unreal tools like execute_script).
# The bridge polls task_status with exponential backoff from MIN to MS:
#   MCP_POLL_INTERVAL_MIN_MS = first poll interval / lower bound (default 100)
#   MCP_POLL_INTERVAL_MS     = ceiling the backoff saturates at (default 2000)
#   MCP_POLL_BACKOFF_FACTOR  = multiplier per iteration until ceiling (default 1.5)
# Short-running scripts return ~MIN ms after completion instead of ~MS ms.
# MCP_POLL_INTERVAL_MIN_MS=100
# MCP_POLL_INTERVAL_MS=2000
# MCP_POLL_BACKOFF_FACTOR=1.5

# Enable debug logging (set to any value to enable)
# DEBUG=1
